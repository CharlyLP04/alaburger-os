# Variables de entorno para A La Burger OS - Servidor

# Puerto en el que correrá el servidor
PORT=3000

# URL de conexión a la base de datos PostgreSQL
# Formato: postgresql://usuario:contraseña@host:puerto/nombre_base_datos
DB_URL=postgresql://usuario:contraseña@localhost:5432/alaburger_os

# Clave secreta para firmar los tokens JWT (usa una cadena larga y aleatoria)
JWT_SECRET=tu_clave_secreta_muy_segura_aqui
